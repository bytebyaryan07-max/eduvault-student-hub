rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false; // Admin only, or disabled

      function isValidUser(data) {
        return data.keys().hasAll(['id', 'displayName', 'email', 'role'])
          && data.id == request.auth.uid
          && data.displayName is string && data.displayName.size() > 0
          && data.email is string && data.email.size() > 0
          && data.role in ['student', 'teacher', 'admin'];
      }

      // --- User Bookmarks Subcollection ---
      match /bookmarks/{bookmarkId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId) && isValidBookmark(request.resource.data);

        function isValidBookmark(data) {
          return data.keys().hasAll(['id', 'resourceId', 'userId', 'addedAt'])
            && data.userId == request.auth.uid
            && data.resourceId is string
            && data.id == bookmarkId;
        }
      }
    }

    // --- Resources Collection ---
    match /resources/{resourceId} {
      allow read: if true; // Public access to discover resources
      allow create: if (isAuthenticated() && isValidResource(request.resource.data) && request.resource.data.uploadedBy == request.auth.uid) || (isValidResource(request.resource.data) && request.resource.data.uploadedBy == "system-seed");
      allow update: if isAuthenticated() && (
        // Owner can update full resource
        (resource.data.uploadedBy == request.auth.uid && isValidResource(request.resource.data)) ||
        // Other users can increment downloadCount or likesCount
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['downloadCount', 'likesCount']) &&
         request.resource.data.uploadedBy == resource.data.uploadedBy)
      );
      allow delete: if isAuthenticated() && resource.data.uploadedBy == request.auth.uid;

      function isValidResource(data) {
        return data.keys().hasAll(['id', 'title', 'category', 'subject', 'course', 'uploadedBy', 'uploadedByName', 'uploadedAt'])
          && data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && data.category is string && data.category.size() > 0
          && data.subject is string && data.subject.size() > 0
          && data.course is string && data.course.size() > 0
          && (data.uploadedBy == "system-seed" || (isAuthenticated() && data.uploadedBy == request.auth.uid));
      }

      // --- Resource Comments Subcollection ---
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidComment(request.resource.data) && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/resources/$(resourceId)).data.uploadedBy == request.auth.uid);

        function isValidComment(data) {
          return data.keys().hasAll(['id', 'resourceId', 'userId', 'userName', 'text', 'createdAt'])
            && data.id == commentId
            && data.resourceId == resourceId
            && data.userId == request.auth.uid
            && data.text is string && data.text.size() > 0 && data.text.size() <= 1000;
        }
      }
    }
  }
}
